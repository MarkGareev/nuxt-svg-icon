{
  "name": "nuxt-svg-icon-module",
  "version": "1.0.1",
  "description": "Nuxt module for lazy-loading inline SVG icons from your assets directory",
  "repository": "https://github.com/markgareev/nuxt-svg-icon",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxi prepare playground",
    "release": "pnpm run lint && pnpm run test && pnpm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@nuxt/kit": "^4.0.3"
  },
  "devDependencies": {
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.0.3",
    "@nuxt/test-utils": "^4.0.3",
    "changelogen": "^0.6.2",
    "eslint": "^10.3.0",
    "happy-dom": "^20.9.0",
    "nuxt": "^4.0.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.8"
  },
  "keywords": [
    "nuxt",
    "nuxt-module",
    "svg",
    "icon",
    "vue"
  ]
}
